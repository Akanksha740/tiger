# Copy to .env and fill in values (both are gitignored)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tiger
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

KALSHI_ENV=prod
KALSHI_KEY_ID=your-key-id
KALSHI_PRIVATE_KEY_PATH=secrets/kalshi_private.key

TIGER_POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
TIGER_POLYMARKET_PAGE_LIMIT=100

TIGER_INGESTION_POLYMARKET_EVENTS_ENABLED=false
TIGER_INGESTION_POLYMARKET_CATALOG_ENABLED=false
TIGER_INGESTION_POLYMARKET_CATALOG_START_OFFSET=0
TIGER_INGESTION_POLYMARKET_CATALOG_MAX_PAGES=0
TIGER_INGESTION_KALSHI_SERIES_ENABLED=false
TIGER_INGESTION_KALSHI_EVENTS_ENABLED=false
TIGER_INGESTION_KALSHI_OPEN_MARKETS_ENABLED=false
TIGER_INGESTION_KALSHI_CATALOG_ENABLED=false
TIGER_INGESTION_KALSHI_CATALOG_REFRESH_SERIES=false
TIGER_INGESTION_KALSHI_CATALOG_INCREMENTAL=false
TIGER_INGESTION_KALSHI_EVENTS_INCREMENTAL=false
TIGER_INGESTION_EXIT_ON_COMPLETE=false
